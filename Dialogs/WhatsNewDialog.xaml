<Window x:Class="HdrBridge.Dialogs.WhatsNewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HdrBridge Updated" Height="400" Width="500"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Icon="pack://application:,,,/Resources/app.ico"
        Topmost="True">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="What's New in HdrBridge" FontSize="24" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBlock x:Name="VersionText" FontSize="16" Foreground="#007ACC" Margin="0,0,0,20"/>
        
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="#2D2D30" Padding="15">
            <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" Foreground="#DADADA" FontFamily="Consolas"/>
        </ScrollViewer>
        
        <Button Grid.Row="3" Content="Awesome!" Click="CloseButton_Click" HorizontalAlignment="Right" Width="100" Margin="0,20,0,0"
                Background="#007ACC" Foreground="White" BorderThickness="0" Padding="10,8" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
