<Window x:Class="HdrBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:hdrBridge="clr-namespace:HdrBridge"
        Title="HdrBridge" Height="700" Width="550"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI"
        Icon="pack://application:,,,/Resources/app.ico">

    <Window.Resources>
        <!-- Dark Mode SystemOverrides for native controls -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D30"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#007ACC"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#3F3F46"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>

        <hdrBridge:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <hdrBridge:EnumMatchToVisibilityConverter x:Key="EnumMatchToVisibilityConverter"/>
        <hdrBridge:EnumMatchToBoolConverter x:Key="EnumMatchToBoolConverter"/>
        <hdrBridge:BoolToStringConverter x:Key="BoolToStringConverter"/>
        <hdrBridge:RGBToColorConverter x:Key="RGBToColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,5,0,20"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="false" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                            <Path Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,8,30,8" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#2D2D30" BorderThickness="1" BorderBrush="#3F3F46" CornerRadius="4" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Panel" Padding="20,10" Margin="0,0,4,0" Background="#2D2D30" CornerRadius="4,4,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Panel" Property="Background" Value="#007ACC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="{Binding TrayIconSource}"
                        ToolTipText="{Binding TrayToolTipText}"
                        TrayLeftMouseUp="TrayIcon_TrayLeftMouseUp"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Opened="TrayContextMenu_Opened">
                    <MenuItem x:Name="SyncToggleMenuItem" Header="Disable Sync" Click="SyncToggleMenuItem_Click" />
                    <MenuItem Header="Open Settings" Click="MenuItem_Open_Click" />
                    <MenuItem Header="Brightness">
                        <MenuItem Header="100%" Click="Brightness_Click" Tag="0" IsCheckable="False"/>
                        <MenuItem Header="75%" Click="Brightness_Click" Tag="1" IsCheckable="False"/>
                        <MenuItem Header="50%" Click="Brightness_Click" Tag="2" IsCheckable="False"/>
                        <MenuItem Header="25%" Click="Brightness_Click" Tag="3" IsCheckable="False"/>
                        <Separator/>
                        <MenuItem Header="+10%" Click="Brightness_Change" Tag="0" StaysOpenOnClick="True"/>
                        <MenuItem Header="-10%" Click="Brightness_Change" Tag="1" StaysOpenOnClick="True"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Exit" Click="MenuItem_Exit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Fill="{Binding CurrentModeColor}" Width="16" Height="16" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding CurrentModeString}" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="{Binding IsUsbConnected, Converter={StaticResource BoolToColorConverter}}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding IsUsbConnected, Converter={StaticResource BoolToStringConverter}, ConverterParameter='USB Connected|USB Disconnected'}" 
                                   Foreground="{Binding IsUsbConnected, Converter={StaticResource BoolToColorConverter}}" 
                                   FontWeight="SemiBold" Margin="0,0,20,0"/>

                        <Ellipse Width="12" Height="12" Fill="{Binding IsUdpListening, Converter={StaticResource BoolToColorConverter}}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding IsUdpListening, Converter={StaticResource BoolToStringConverter}, ConverterParameter='UDP Listening|UDP Not Listening'}" 
                                   Foreground="{Binding IsUdpListening, Converter={StaticResource BoolToColorConverter}}" 
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Ellipse Width="12" Height="12" Fill="{Binding IsHyperHdrServerReachable, Converter={StaticResource BoolToColorConverter}}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding IsHyperHdrServerReachable, Converter={StaticResource BoolToStringConverter}, ConverterParameter='HyperHDR API: reachable|HyperHDR API: unreachable'}" 
                                   Foreground="{Binding IsHyperHdrServerReachable, Converter={StaticResource BoolToColorConverter}}" 
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
                
                <Button Grid.Column="1" Command="{Binding ToggleServicesCommand}" Foreground="White" BorderThickness="0" Padding="12,8" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Content>
                        <TextBlock Text="{Binding ServicesButtonLabel}" FontSize="14" FontWeight="SemiBold"/>
                    </Button.Content>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#60A917"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="border" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <!-- Paused by user -->
                                <DataTrigger Binding="{Binding IsServicesEnabled}" Value="False">
                                    <Setter Property="Background" Value="#E51400"/>
                                </DataTrigger>
                                <!-- No controller connected — shown on top, highest priority -->
                                <DataTrigger Binding="{Binding IsUsbConnected}" Value="False">
                                    <Setter Property="Background" Value="#CA5010"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>

        <TabControl Grid.Row="1" Background="#252526" BorderThickness="0" Foreground="White">
            
            <!-- DASHBOARD TAB -->
            <TabItem Header="Dashboard">
                <StackPanel Margin="20">
                    <TextBlock Text="Select Operating Mode" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                        <RadioButton Content="HyperHDR Sync" IsChecked="{Binding CurrentMode, Converter={StaticResource EnumMatchToBoolConverter}, ConverterParameter=HyperHDRSync}" />
                        <RadioButton Content="Solid Color" IsChecked="{Binding CurrentMode, Converter={StaticResource EnumMatchToBoolConverter}, ConverterParameter=StaticColor}" />
                        <RadioButton Content="Hardware Effects" IsChecked="{Binding CurrentMode, Converter={StaticResource EnumMatchToBoolConverter}, ConverterParameter=HardwareEffect}" />
                    </StackPanel>

                    <!-- Dynamic Layer: Hyper HDR -->
                    <StackPanel Visibility="{Binding CurrentMode, Converter={StaticResource EnumMatchToVisibilityConverter}, ConverterParameter=HyperHDRSync}">
                        <TextBlock Text="This mode bridges HyperHDR UDP frames directly to your LED strip. Make sure HyperHDR is broadcasting securely to your computer." TextWrapping="Wrap" Margin="0,0,0,20"/>
                        <Border Background="#1E1E1E" CornerRadius="8" Padding="15">
                            <TextBlock Text="{Binding SettingsService.CurrentSettings.UdpPort, StringFormat='Listening on UDP {0}...'}" FontWeight="SemiBold" Foreground="#007ACC" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Max Brightness Slider -->
                        <TextBlock Margin="0,25,0,0" FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Max Brightness: {0}%">
                                    <Binding Path="HyperHdrMaxBrightness"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Slider Minimum="0" Maximum="100" Value="{Binding HyperHdrMaxBrightness, Delay=150}" 
                                IsSnapToTickEnabled="True" TickFrequency="1" Margin="0,5,0,0"
                                IsEnabled="{Binding IsHyperHdrServerReachable}"/>
                    </StackPanel>

                    <!-- Dynamic Layer: Solid Color Picker -->
                    <StackPanel Visibility="{Binding CurrentMode, Converter={StaticResource EnumMatchToVisibilityConverter}, ConverterParameter=StaticColor}">
                        <TextBlock Text="Solid Color Tuning" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        
                        <xctk:ColorCanvas SelectedColor="{Binding StaticColorMedia, Mode=TwoWay}" Background="Transparent" Foreground="White" BorderThickness="0" Margin="0,0,0,20" />
                        
                    </StackPanel>

                    <!-- Dynamic Layer: Hardware Effects -->
                    <StackPanel Visibility="{Binding CurrentMode, Converter={StaticResource EnumMatchToVisibilityConverter}, ConverterParameter=HardwareEffect}">
                        <TextBlock Text="Hardware Effects Engine" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <ComboBox ItemsSource="{Binding AvailableEffects}" SelectedItem="{Binding SelectedHardwareEffect}" Margin="0,0,0,25" Padding="6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2,3,2,3">
                                        <TextBlock Text="{Binding Category}" Foreground="#888888" FontWeight="SemiBold" FontSize="11" Width="55" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <TextBlock>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}: {1}%">
                                    <Binding Path="SliderLabel"/>
                                    <Binding Path="HardwareEffectSpeed"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Slider Minimum="0" Maximum="100" Value="{Binding HardwareEffectSpeed, Delay=100}" IsSnapToTickEnabled="True" TickFrequency="1" Margin="0,0,0,20" />
                        
                    </StackPanel>
                    
                </StackPanel>
            </TabItem>

            <!-- SETTINGS TAB -->
            <TabItem Header="Settings">
                <StackPanel Margin="20">
                    <TextBlock Text="UDP Port (Default 19446)" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SettingsService.CurrentSettings.UdpPort, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="LED Count" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SettingsService.CurrentSettings.LedCount, UpdateSourceTrigger=PropertyChanged}"/>

                    <CheckBox Content="Run at Windows startup" IsChecked="{Binding SettingsService.CurrentSettings.StartWithWindows}" Foreground="White" Margin="0,15,0,10"
                              Checked="StartupCheckBox_Changed" Unchecked="StartupCheckBox_Changed"/>

                    <CheckBox Content="Auto-off on Lock / Monitor Sleep" IsChecked="{Binding SettingsService.CurrentSettings.AutoOffOnLockSleep}" Foreground="White" Margin="0,0,0,30"
                              Checked="StartupCheckBox_Changed" Unchecked="StartupCheckBox_Changed"/>

                    <Button Content="Apply &amp; Save Settings" Command="{Binding SaveSettingsCommand}" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="12" Cursor="Hand" FontSize="14" FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </TabItem>
            <!-- ABOUT TAB -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <TextBlock Text="About"/>
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="#FF4FC3F7"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="26,-2,0,0"
                                 Visibility="{Binding IsUpdateAttentionRequired, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Opacity" Value="0.35"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpdateAttentionRequired}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0.25"
                                                                         To="1.0"
                                                                         Duration="0:0:0.8"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="30,10">
                        <StackPanel MaxWidth="450">
                            <!-- Header Section -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                                <Grid Width="100" Height="100" Margin="0,0,0,15">
                                    <Ellipse Fill="#2D2D30" Stroke="#007ACC" StrokeThickness="1"/>
                                    <Image Source="pack://application:,,,/Resources/app_hires.ico" Width="64" Height="64">
                                        <Image.Effect>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#007ACC" Opacity="0.4"/>
                                        </Image.Effect>
                                    </Image>
                                </Grid>
                                <TextBlock Text="HdrBridge" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding AppVersion}" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Philosophy Section -->
                            <StackPanel Margin="0,0,0,30">
                                <TextBlock Text="&quot;Born out of frustration.&quot;" FontSize="18" FontStyle="Italic" Foreground="#007ACC" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="A lightweight, zero-bloat bridge for USB-HID Ambilight controllers. Designed to replace resource-heavy generic software with a clean C# implementation that respects your GPU and CPU cycles." 
                                           TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Foreground="#CCCCCC" LineHeight="20"/>
                            </StackPanel>

                            <Border Height="1" Background="#3F3F46" Margin="0,0,0,25" HorizontalAlignment="Stretch"/>

                            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,24">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding IsUpdateSupported, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button Command="{Binding CheckForUpdatesCommand}" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="12,7" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <Grid>
                                                            <TextBlock Text="Check for Updates" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            <Ellipse Width="8"
                                                                     Height="8"
                                                                     Fill="#FF4FC3F7"
                                                                     HorizontalAlignment="Right"
                                                                     VerticalAlignment="Top"
                                                                     Margin="0,-4,-4,0"
                                                                     Visibility="{Binding IsUpdateAttentionRequired, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Opacity" Value="0.35"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUpdateAttentionRequired}" Value="True">
                                                                                <DataTrigger.EnterActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                             From="0.25"
                                                                                                             To="1.0"
                                                                                                             Duration="0:0:0.8"/>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </DataTrigger.EnterActions>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button Command="{Binding DownloadUpdateCommand}" Background="#2D89EF" Foreground="White" BorderThickness="0" Padding="12,7" Cursor="Hand" Margin="8,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="Download"/>
                                        </Button>

                                        <Button Command="{Binding InstallUpdateCommand}" Background="#60A917" Foreground="White" BorderThickness="0" Padding="12,7" Cursor="Hand" Margin="8,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanInstallUpdate}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="Install on Restart"/>
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Text="{Binding UpdateStatusText}" Margin="0,10,0,0" Foreground="#CCCCCC"/>
                                    <TextBlock Text="{Binding LatestUpdateVersion, StringFormat='Latest: {0}'}" Margin="0,4,0,0" Foreground="#888888" Visibility="{Binding IsUpdateSupported, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding UpdateDownloadProgressPercent}"
                                                 Height="10"
                                                 Margin="0,10,0,0"
                                                 Visibility="{Binding IsUpdateProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                    <TextBlock Text="{Binding UpdateDownloadProgressPercent, StringFormat='Download: {0}%'}"
                                               Margin="0,4,0,0"
                                               Foreground="#AAAAAA"
                                               Visibility="{Binding IsUpdateProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                    <TextBlock Text="Release Notes" Margin="0,14,0,6" FontWeight="SemiBold" Foreground="#DDDDDD" Visibility="{Binding IsUpdateSupported, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="140" Background="#1E1E1E" Visibility="{Binding IsUpdateSupported, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding UpdateReleaseNotesMarkdown}"
                                                   TextWrapping="Wrap"
                                                   Padding="10"
                                                   Foreground="#DADADA"
                                                   FontFamily="Consolas"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <!-- Technical Details -->
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Engine" FontSize="11" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="HyperHDR API" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <Border Grid.Column="1" Width="1" Background="#3F3F46" Margin="20,0"/>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="License" FontSize="11" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="MIT Open Source" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- Links & Credits -->
                            <StackPanel Margin="0,0,0,40">
                                <TextBlock Text="Made with ❤️ by GetTheNya" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="14">
                                    <Hyperlink NavigateUri="https://github.com/GetTheNya/HdrBridge" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#007ACC" TextDecorations="None">
                                        github.com/GetTheNya/HdrBridge
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>

                            <!-- Easter Egg / Quote (Inconspicuous) -->
                            <TextBlock Text="&quot;If the software is buggy, rewrite it. If it’s Chinese, reverse engineer it.&quot; — GetTheNya's Engineering Rule #1." 
                                       FontSize="10" Foreground="#969696ff" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.8"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
